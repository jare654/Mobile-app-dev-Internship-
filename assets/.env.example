# ─── PulseNews Environment Configuration ─────────────────────────────────────
#
# SETUP INSTRUCTIONS:
#   1. Copy this file:  cp assets/.env.example assets/.env
#   2. Get your free API key at: https://newsapi.org/register
#   3. Replace the placeholder below with your actual key
#   4. Confirm assets/.env is in .gitignore (it already is)
#
# ⚠ NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

NEWS_API_KEY=your_newsapi_key_here
